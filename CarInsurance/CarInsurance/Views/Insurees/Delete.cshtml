@model CarInsurance.Models.Insuree

<h1>Delete Insuree</h1>

<h3>Are you sure you want to delete this?</h3>

<div>
    <dl class="row">
        <dt class="col-sm-2">First Name</dt>
        <dd class="col-sm-10">@Model.FirstName</dd>

        <dt class="col-sm-2">Last Name</dt>
        <dd class="col-sm-10">@Model.LastName</dd>

        <dt class="col-sm-2">Email</dt>
        <dd class="col-sm-10">@Model.EmailAddress</dd>

        <dt class="col-sm-2">DOB</dt>
        <dd class="col-sm-10">@Model.DateOfBirth.ToShortDateString()</dd>

        <dt class="col-sm-2">Car</dt>
        <dd class="col-sm-10">@Model.CarYear @Model.CarMake @Model.CarModel</dd>

        <dt class="col-sm-2">DUI</dt>
        <dd class="col-sm-10">@Model.DUI</dd>

        <dt class="col-sm-2">Tickets</dt>
        <dd class="col-sm-10">@Model.SpeedingTickets</dd>

        <dt class="col-sm-2">Coverage</dt>
        <dd class="col-sm-10">@Model.CoverageType</dd>

        <dt class="col-sm-2">Quote</dt>
        <dd class="col-sm-10">@Model.Quote</dd>
    </dl>
</div>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
